# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The pull-local.sh script will update IMAGE_TAG with the newest published tag.

# Pinned image tag to run locally.
#   - Leave as `latest` and run:  ./scripts/pull-local.sh
#   - Or set a specific tag: IMAGE_TAG=v0.1.0-abc1234
IMAGE_TAG=latest

# Docker Hub username (for pulling from Docker Hub)
DOCKERHUB_USERNAME=gerytravelio

# Which registry to pull from (ghcr | dockerhub)
REGISTRY=dockerhub

# Port to expose locally
APP_PORT=8080
